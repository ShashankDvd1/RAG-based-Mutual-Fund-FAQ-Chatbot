# Groq Cloud API Settings
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Hosted Embedding Settings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HF_TOKEN=your_huggingface_token_here

# FAISS Local Path
VECTORSTORE_PATH=./data/vectorstore

# Uvicorn Server Configurations
HOST=0.0.0.0
PORT=8000

# CORS Configuration (comma-separated list of origins)
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000
